"""pdf-tools 统一 CLI 入口。"""
import argparse
import os
import sys

from extractor import extract_images


def default_output_dir(pdf_path):
    base_name = os.path.splitext(os.path.basename(pdf_path))[0]
    return f"{base_name}_images"


def run_extract(pdf_path, output_dir=None):
    if not os.path.isfile(pdf_path):
        print(f"错误：输入文件不存在: {pdf_path}", file=sys.stderr)
        sys.exit(1)

    if not output_dir:
        output_dir = default_output_dir(pdf_path)

    try:
        saved_paths = extract_images(pdf_path, output_dir)
    except Exception as e:
        print(f"错误：无法处理PDF文件: {e}", file=sys.stderr)
        sys.exit(1)

    if not saved_paths:
        print("未找到图片")
    else:
        print(f"提取到 {len(saved_paths)} 张图片，已保存到: {output_dir}")


FEATURES = [
    ("提取图片", run_extract),
]


def run_menu():
    print("支持的功能：")
    for i, (name, _) in enumerate(FEATURES, start=1):
        print(f"  {i}. {name}")

    choice = input("请选择功能 [1]: ").strip() or "1"
    if not choice.isdigit() or not (1 <= int(choice) <= len(FEATURES)):
        print(f"错误：无效的功能编号: {choice}", file=sys.stderr)
        sys.exit(1)

    pdf_path = input("请输入 PDF 路径: ").strip()
    if not pdf_path:
        print("错误：未输入 PDF 路径", file=sys.stderr)
        sys.exit(1)
    if not os.path.isfile(pdf_path):
        print(f"错误：输入文件不存在: {pdf_path}", file=sys.stderr)
        sys.exit(1)

    default_dir = default_output_dir(pdf_path)
    output_dir = input(f"输出目录（回车使用默认 {default_dir}/）: ").strip()

    _, feature_func = FEATURES[int(choice) - 1]
    feature_func(pdf_path, output_dir or None)


def main():
    if len(sys.argv) > 1:
        parser = argparse.ArgumentParser(
            description="Extract embedded images from a PDF file."
        )
        parser.add_argument("input", help="Path to the input PDF file")
        parser.add_argument(
            "-o", "--output", help="Output directory for extracted images"
        )
        args = parser.parse_args()
        run_extract(args.input, args.output)
    else:
        run_menu()


if __name__ == "__main__":
    main()
